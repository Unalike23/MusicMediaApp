<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bd1">

    <application
        android:allowBackup="true"
        android:icon="@drawable/music_media_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/music_media_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BD1">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".DetailActivity"
            android:label="Détails du produit"
            android:parentActivityName=".MainActivity">
            <!-- Chapitre 2 : Définition de l'activité parente -->
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.bd1.MainActivity" />
        </activity>
        <activity
            android:name=".FavorisActivity"
            android:label="@string/title_favoris"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.bd1.MainActivity" />
        </activity>
    </application>

</manifest>